{
  "coq-lsp.path": ".vscode/coq-lsp-nix.sh",
  "coq-lsp.args": [],
  "coq-lsp.trace.server": "off",
  "files.associations": {
    "*.v": "coq"
  },
  "files.exclude": {
    "**/*.vo": true,
    "**/*.vok": true,
    "**/*.vos": true,
    "**/*.aux": true,
    "**/*.glob": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  "coq-lsp.check_only_on_request": false
}
